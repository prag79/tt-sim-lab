#!/usr/bin/env bash
# /usr/local/bin/ttlab - dispatcher for the ttsim labs.
# Usage: ttlab {list|00|01|...|06|10|...|16|setup|ssh|stop|shell}
#
# On first run of `ttlab NN`, the canonical (root-owned, image-baked) lab dir
# under $LABS_ROOT is mirrored into $WORK_ROOT/<lab-name>/ so the student can
# edit READMEs / scripts without touching the read-only image. `cp -ru` is
# idempotent: re-running won't clobber edits but pulls in new upstream files.
#
# Two tracks:
#   Primary (kernel programming)  00-06  - TT-Metalium on a virtual Wormhole
#       via the library-direct flow (`tt-sim`); intro examples then matmul.
#   Advanced (bring-up, optional) 10-16  - QEMU + tt-kmd (the `tt-guest` helper).

set -euo pipefail

LABS_ROOT="${LABS_ROOT:-/labs}"
WORK_ROOT="${WORK_ROOT:-$HOME/work}"

prepare_workdir() {
  local lab="$1"
  local src="$LABS_ROOT/$lab"
  local dst="$WORK_ROOT/$lab"
  [[ -d "$src" ]] || { echo "ttlab: no such lab '$lab' under $LABS_ROOT" >&2; exit 1; }
  mkdir -p "$dst"
  cp -ru "$src/." "$dst/"
  cd "$dst"
}

banner() {
  printf '\n\033[1;36m== %s ==\033[0m\n' "$1"
  echo "Full walkthrough: $WORK_ROOT/$2/README.md"
  echo
}

metal_ready_hint() {
  if [[ -d "${TT_METAL_HOME:-/opt/tt-metal}/build" ]]; then
    echo "tt-metal is ready — run:"
  else
    echo "Light image: run 'tt-sim setup' once, then:"
  fi
}

cmd="${1:-list}"; shift || true

case "$cmd" in
  list|"")
    cat <<'EOF'
Available labs:

  Primary track - kernel programming on a virtual Wormhole (library-direct):
    00     - orientation: verify the env (tt-metal should already be built on FULL)
    01     - elementwise add (TT-Metalium intro — reader/compute/writer, CBs)
    02     - multicast intro on the NoC (semaphores, sender/receivers)
    03     - TTNN high-level add (optional — no custom kernels)
    04     - single-core matrix multiplication
    05     - multi-core matrix multiplication (SPMD across the Tensix grid)
    06     - multicast for data reuse in multi-core matmul

  Advanced track - QEMU + tt-kmd bring-up (optional):
    10     - boot a Linux guest under QEMU full-system (no device yet)
    11     - attach a virtual Wormhole PCIe device; find it with lspci
    12     - build & load tt-kmd; surface /dev/tenstorrent/0
    13     - inspect the virtual device (sysfs, BARs, config space)
    14     - run a tt-metal app through the full QEMU + driver path
    15     - Blackhole bring-up + a look at multichip (N300/P300/T3000/Galaxy)
    16     - read the one QEMU patch: hw/misc/ttsim.c, the PCI device model

  Helpers:
    setup  - provision/build tt-metal for the kernel labs (tt-sim setup)
    ssh    - ssh into the running guest (advanced track; also: tt-guest ssh)
    stop   - power off the running guest (advanced track)
    shell  - drop to a plain bash shell

New here? Do 00 -> 01 -> 02 -> (03 optional) -> 04 -> 05 -> 06.
Advanced track (10-16) is optional.
EOF
    ;;

  00|00-orientation)
    prepare_workdir 00-orientation
    exec bash check.sh
    ;;

  01|01-elementwise-binary)
    prepare_workdir 01-elementwise-binary
    banner "Lab 01 - elementwise add (Metalium intro)" 01-elementwise-binary
    metal_ready_hint
    echo "  tt-sim run example_lab_eltwise_binary"
    exec bash
    ;;

  02|02-multicast-intro)
    prepare_workdir 02-multicast-intro
    banner "Lab 02 - multicast intro" 02-multicast-intro
    metal_ready_hint
    echo "  tt-sim run example_lab_multicast"
    exec bash
    ;;

  03|03-ttnn-add)
    prepare_workdir 03-ttnn-add
    banner "Lab 03 - TTNN high-level add (optional)" 03-ttnn-add
    metal_ready_hint
    echo "  tt-sim run example_add"
    exec bash
    ;;

  04|04-matmul-single-core)
    prepare_workdir 04-matmul-single-core
    banner "Lab 04 - single-core matrix multiplication" 04-matmul-single-core
    metal_ready_hint
    echo "  tt-sim run metal_example_matmul_single_core"
    exec bash
    ;;

  05|05-matmul-multi-core)
    prepare_workdir 05-matmul-multi-core
    banner "Lab 05 - multi-core matrix multiplication" 05-matmul-multi-core
    echo "Run:  tt-sim run metal_example_matmul_multi_core"
    exec bash
    ;;

  06|06-matmul-multicast)
    prepare_workdir 06-matmul-multicast
    banner "Lab 06 - multicast for data reuse in matmul" 06-matmul-multicast
    echo "Run:  tt-sim run metal_example_matmul_multicore_reuse_mcast"
    exec bash
    ;;

  setup)
    exec tt-sim setup "$@"
    ;;

  10|10-boot-guest)
    prepare_workdir 10-boot-guest
    banner "Lab 10 - boot a Linux guest (no Tenstorrent device)" 10-boot-guest
    exec tt-guest boot --device none
    ;;

  11|11-attach-ttsim)
    prepare_workdir 11-attach-ttsim
    banner "Lab 11 - attach a virtual Wormhole PCIe device" 11-attach-ttsim
    exec tt-guest boot --device wh
    ;;

  12|12-load-kmd)
    prepare_workdir 12-load-kmd
    banner "Lab 12 - build & load tt-kmd, surface /dev/tenstorrent/0" 12-load-kmd
    exec tt-guest boot --device wh
    ;;

  13|13-inspect-device)
    prepare_workdir 13-inspect-device
    banner "Lab 13 - inspect the virtual device" 13-inspect-device
    exec tt-guest boot --device wh
    ;;

  14|14-tt-metal-qemu)
    prepare_workdir 14-tt-metal-qemu
    banner "Lab 14 - run a tt-metal app via the full QEMU + driver path" 14-tt-metal-qemu
    exec tt-guest boot --device wh
    ;;

  15|15-blackhole-multichip)
    prepare_workdir 15-blackhole-multichip
    banner "Lab 15 - Blackhole bring-up + multichip preview" 15-blackhole-multichip
    exec tt-guest boot --device bh
    ;;

  16|16-the-qemu-patch)
    prepare_workdir 16-the-qemu-patch
    banner "Lab 16 - read the one QEMU patch (hw/misc/ttsim.c)" 16-the-qemu-patch
    exec bash explore.sh
    ;;

  ssh)
    exec tt-guest ssh "$@"
    ;;

  stop)
    exec tt-guest stop
    ;;

  shell)
    exec bash
    ;;

  -h|--help|help)
    echo "usage: ttlab {list|00|01|02|03|04|05|06|10|11|12|13|14|15|16|setup|ssh|stop|shell}"
    echo
    echo "ttlab NN mirrors /labs/<NN-...>/ into $WORK_ROOT/<NN-...>/ and runs it."
    echo "Primary track (00-06): intro examples + matmul via 'tt-sim' (library-direct)."
    echo "Advanced track (10-16): QEMU + tt-kmd bring-up via 'tt-guest'."
    ;;

  *)
    echo "ttlab: unknown command '$cmd'" >&2
    echo "usage: ttlab {list|00|01|02|03|04|05|06|10|11|12|13|14|15|16|setup|ssh|stop|shell}" >&2
    exit 1
    ;;
esac
