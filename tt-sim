#!/usr/bin/env bash
# /usr/local/bin/tt-sim - drive tt-metal against a *virtual* Tenstorrent chip
# using the ttsim **library-direct** flow (no QEMU, no tt-kmd, no guest VM).
#
# This is the engine behind the primary "kernel programming" track (the matmul
# labs). tt-metal is pointed straight at /opt/ttsim/libttsim_wh.so via the
# TT_METAL_SIMULATOR env var, so the whole boot -> driver -> PCIe stack is
# bypassed. It is dramatically lighter and faster than the QEMU/KMD path
# (labs 10-16) and is the right backend for learning kernel programming, where
# the device's driver/PCIe layer is not the subject being taught.
#
# Subcommands:
#   tt-sim setup            ensure tt-metal is present & built, wire up the
#                           library-direct soc descriptor (idempotent)
#   tt-sim build            (re)build tt-metal
#   tt-sim env              print the env exports for the library-direct flow
#   tt-sim run <example>    run a tt-metal programming example under ttsim
#   tt-sim patch-output      inject sample result lines into labs 01–06 examples
#   tt-sim patch-eltwise     (alias for patch-output)
#   tt-sim shell            drop into a shell with the env already exported
#   tt-sim status           show where tt-metal lives and whether it is built
#
# Resolution order for the tt-metal tree (first hit wins):
#   $TT_METAL_HOME  ->  /opt/tt-metal (image-baked)  ->  ~/work/tt-metal (built
#   on first `tt-sim setup`, persists across Codespace stop/start).

set -euo pipefail

TTSIM_DIR="${TTSIM_DIR:-/opt/ttsim}"
WORK_ROOT="${WORK_ROOT:-$HOME/work}"
WORK_TT_METAL="$WORK_ROOT/tt-metal"
PREBAKED_TT_METAL="/opt/tt-metal"

# tt-metal branch/tag/commit to build. Pinned to the merge commit of the
# ttsim Wormhole fix (PR #46871) for a known-good, reproducible build.
# Override with TT_METAL_REF (a branch like 'main', a tag, or a commit SHA).
TT_METAL_REPO="${TT_METAL_REPO:-https://github.com/tenstorrent/tt-metal}"
TT_METAL_REF="${TT_METAL_REF:-5a4436244ae1b421504da84c01f81fdfdf6049de}"

ARCH="$(uname -m)"
case "$ARCH" in
  x86_64|amd64)   LIB_SUFFIX="" ;;
  aarch64|arm64)  LIB_SUFFIX="_aarch64" ;;
  *) echo "tt-sim: unsupported host arch '$ARCH'" >&2; exit 1 ;;
esac

WH_LIB="$TTSIM_DIR/libttsim_wh${LIB_SUFFIX}.so"

die() { echo "tt-sim: $*" >&2; exit 1; }

resolve_patch_script() {
  local name="$1"
  local script
  for script in \
    "/usr/local/share/tt-sim-lab/$name" \
    "$(dirname "$0")/scripts/$name"; do
    [[ -f "$script" ]] && { echo "$script"; return 0; }
  done
  return 1
}

apply_lab_output_patches() {
  local home="$1"
  local script
  script="$(resolve_patch_script patch-lab-output.py)" || \
    die "patch-lab-output.py not found (rebuild the lab image or run from the git repo)"
  python3 "$script" "$home"
}

rebuild_lab_output_examples() {
  local home="$1"
  echo "==> Rebuilding lab examples with sample output..."
  ( cd "$home" && TT_METAL_HOME="$home" cmake --build build --target \
      example_lab_eltwise_binary \
      example_lab_multicast \
      example_add \
      metal_example_matmul_single_core \
      metal_example_matmul_multi_core \
      metal_example_matmul_multicore_reuse_mcast )
}

# --- locate the tt-metal tree ----------------------------------------------

resolve_home() {
  if [[ -n "${TT_METAL_HOME:-}" && -d "$TT_METAL_HOME" ]]; then
    echo "$TT_METAL_HOME"; return 0
  fi
  if [[ -d "$PREBAKED_TT_METAL" ]]; then
    echo "$PREBAKED_TT_METAL"; return 0
  fi
  if [[ -d "$WORK_TT_METAL" ]]; then
    echo "$WORK_TT_METAL"; return 0
  fi
  return 1
}

is_built() {
  local home="$1"
  [[ -d "$home/build" ]] || return 1
  compgen -G "$home/build/programming_examples/*" >/dev/null 2>&1 && return 0
  compgen -G "$home/build/ttnn/examples/*" >/dev/null 2>&1
}

# --- wire up the library-direct soc descriptor -----------------------------
# In the library-direct flow tt-metal reads a soc_descriptor.yaml that sits
# next to the .so. We copy Wormhole's descriptor there (idempotent).
wire_soc_descriptor() {
  local home="$1"
  local desc="$home/tt_metal/soc_descriptors/wormhole_b0_80_arch.yaml"
  local dest="$TTSIM_DIR/soc_descriptor.yaml"
  [[ -f "$desc" ]] || die "soc descriptor not found at $desc (is tt-metal checked out?)"

  # Already wired up and identical? Nothing to do. This is the common case on
  # the :full image, where the descriptor is baked in (root-owned) at build
  # time — re-copying it would fail with "Permission denied".
  if [[ -f "$dest" ]] && cmp -s "$desc" "$dest"; then
    return 0
  fi

  # Needs (re)writing. Use a plain copy when /opt/ttsim is writable, else fall
  # back to sudo (the lab image grants the student NOPASSWD sudo).
  if [[ -w "$TTSIM_DIR" && ( ! -e "$dest" || -w "$dest" ) ]]; then
    cp -f "$desc" "$dest"
  else
    sudo cp -f "$desc" "$dest"
  fi
}

# --- subcommands -----------------------------------------------------------

cmd_build() {
  local home="$1"
  apply_lab_output_patches "$home" || true
  # tt-metal ships its own dependency installer; run it best-effort so a fresh
  # tree builds on the minimal lab image (student has NOPASSWD sudo).
  if [[ -x "$home/install_dependencies.sh" ]]; then
    echo "==> Installing tt-metal build dependencies (sudo)..."
    ( cd "$home" && sudo ./install_dependencies.sh ) || \
      echo "tt-sim: install_dependencies.sh failed; continuing (deps may already be present)" >&2
  fi
  echo "==> Building tt-metal in $home (this is the heavy step; grab a coffee)..."
  # --build-programming-examples is what produces the metal_example_matmul_*
  # binaries the labs run; without it `tt-sim run` finds nothing.
  ( cd "$home" && TT_METAL_HOME="$home" ./build_metal.sh --build-programming-examples )
  echo "==> tt-metal build complete."
}

cmd_setup() {
  [[ -f "$WH_LIB" ]] || die "missing $WH_LIB (the virtual Wormhole library)"

  local home
  if home="$(resolve_home)"; then
    echo "==> Using tt-metal at: $home"
  else
    echo "==> No tt-metal tree found. Cloning into $WORK_TT_METAL ..."
    echo "    (ref: $TT_METAL_REF — must include PR #46871 for Wormhole/ttsim)"
    mkdir -p "$WORK_ROOT"
    # Clone then check out the ref so it works for a branch, tag, OR commit SHA.
    git clone "$TT_METAL_REPO" "$WORK_TT_METAL"
    ( cd "$WORK_TT_METAL" && git checkout "$TT_METAL_REF" && \
      git submodule update --init --recursive )
    home="$WORK_TT_METAL"
  fi

  if is_built "$home"; then
    echo "==> tt-metal already built."
  else
    cmd_build "$home"
  fi

  wire_soc_descriptor "$home"
  echo
  echo "==> Ready. Library-direct ttsim is wired up:"
  cmd_env "$home"
}

cmd_patch_output() {
  local home; home="$(resolve_home)" || die "no tt-metal tree; run 'tt-sim setup' first"
  echo "==> Patching lab examples to print sample results (labs 01–06)..."
  apply_lab_output_patches "$home"
  rebuild_lab_output_examples "$home"
  echo "==> Done. Re-run e.g.: tt-sim run example_lab_eltwise_binary"
}

cmd_patch_eltwise() {
  cmd_patch_output "$@"
}

cmd_env() {
  local home="${1:-$(resolve_home || true)}"
  [[ -n "$home" ]] || die "no tt-metal tree found; run 'tt-sim setup' first"
  cat <<EOF
export TT_METAL_HOME="$home"
export TT_METAL_RUNTIME_ROOT="$home"
export TT_METAL_SIMULATOR="$WH_LIB"
export TT_METAL_SLOW_DISPATCH_MODE=1
export TT_METAL_DISABLE_SFPLOADMACRO=1
export TT_LOGGER_TYPES="${TT_LOGGER_TYPES:-Always}"
EOF
}

summarize_run_log() {
  local log="$1"
  if grep -qE '\| *Always \|' "$log" 2>/dev/null; then
    grep -E '\| *Always \|' "$log" \
      | sed -E 's/^.*\| *Always \| //' \
      | sed -E 's/ \([^)]+\)$//'
  fi
  grep -E '^(Output vector of size|Metalium vs Golden|Matrix multiply|Sample C\[|Sample results|Matrix shape|TTNN add|Output tensor:|Multicast example|Launching multicast|Multicast complete|Output vector size:|\[PASS\]|\[FAIL\]|Test Passed|Test Failed)' "$log" 2>/dev/null || true
  grep -E '^(  \[[0-9]+\]|    \[[0-9]+\]|  C\[[0-9]+\]|  out\[[0-9]+\])' "$log" 2>/dev/null || true
}

cmd_run() {
  local home; home="$(resolve_home)" || die "no tt-metal tree; run 'tt-sim setup' first"
  is_built "$home" || die "tt-metal not built; run 'tt-sim setup' first"
  [[ $# -ge 1 ]] || die "usage: tt-sim run <example-binary> [args...]"

  wire_soc_descriptor "$home"
  export TT_METAL_HOME="$home"
  export TT_METAL_RUNTIME_ROOT="$home"
  export TT_METAL_SIMULATOR="$WH_LIB"
  export TT_METAL_SLOW_DISPATCH_MODE=1
  export TT_METAL_DISABLE_SFPLOADMACRO=1

  local target="$1"; shift
  # Accept either a bare example name or a path under build/.
  if [[ -x "$target" ]]; then
    : # absolute/relative path given
  elif [[ -x "$home/build/programming_examples/$target" ]]; then
    target="$home/build/programming_examples/$target"
  elif [[ -x "$home/build/ttnn/examples/$target" ]]; then
    target="$home/build/ttnn/examples/$target"
  else
    die "example '$target' not found (look under $home/build/programming_examples/ or $home/build/ttnn/examples/)"
  fi

  # Default: show program result lines (LogAlways) without Metal/UMD bring-up
  # noise. Set TT_LOGGER_TYPES=All before running to see full logs.
  export TT_LOGGER_TYPES="${TT_LOGGER_TYPES:-Always}"

  echo "==> Running $target under library-direct ttsim (Wormhole)"
  local log rc=0
  log="$(mktemp "${TMPDIR:-/tmp}/tt-sim-run.XXXXXX")"
  trap 'rm -f "$log"' RETURN
  "$target" "$@" 2>&1 | tee "$log" || rc=$?

  echo ""
  echo "==> Result"
  summarize_run_log "$log"

  return "$rc"
}

cmd_shell() {
  local home; home="$(resolve_home)" || die "no tt-metal tree; run 'tt-sim setup' first"
  wire_soc_descriptor "$home"
  echo "==> Shell with library-direct ttsim env exported. Type 'exit' to leave."
  TT_METAL_HOME="$home" \
  TT_METAL_RUNTIME_ROOT="$home" \
  TT_METAL_SIMULATOR="$WH_LIB" \
  TT_METAL_SLOW_DISPATCH_MODE=1 \
  TT_METAL_DISABLE_SFPLOADMACRO=1 \
  TT_LOGGER_TYPES="${TT_LOGGER_TYPES:-Always}" \
    exec bash
}

cmd_status() {
  echo "Virtual chip library : $WH_LIB $( [[ -f "$WH_LIB" ]] && echo '(present)' || echo '(MISSING)')"
  local home
  if home="$(resolve_home)"; then
    echo "tt-metal tree        : $home"
    if is_built "$home"; then
      echo "tt-metal build       : built"
    else
      echo "tt-metal build       : NOT built (run 'tt-sim setup')"
    fi
  else
    echo "tt-metal tree        : none found (run 'tt-sim setup')"
  fi
}

cmd="${1:-status}"; shift || true
case "$cmd" in
  setup)        cmd_setup "$@" ;;
  build)        home="$(resolve_home)" || die "no tt-metal tree; run 'tt-sim setup' first"; cmd_build "$home" ;;
  patch-output|patch-eltwise) cmd_patch_output "$@" ;;
  env)          cmd_env "$@" ;;
  run)          cmd_run "$@" ;;
  shell)        cmd_shell "$@" ;;
  status)       cmd_status "$@" ;;
  -h|--help|help)
    sed -n '2,29p' "$0" | sed 's/^# \{0,1\}//'
    ;;
  *) die "unknown subcommand '$cmd' (try: setup|build|patch-output|env|run|shell|status)" ;;
esac
